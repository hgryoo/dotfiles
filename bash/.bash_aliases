# Basic
alias ll='ls -alF'
alias la='ls -A'
alias vi='vim'

# Git
alias gs='git status'
alias gb='git branch'
alias gl='git log --oneline --graph'
alias gd='git diff'
alias gc='git commit'
alias gp='git push'

# Build tools
alias cm='cmake -GNinja'
alias mk='ninja -C build'
alias cb='cd ~/cubrid'

# Python
alias py='python3'

# Rust
alias rr='cargo run'
alias rb='cargo build'
alias rt='cargo test'
alias rc='cargo check'
alias ru='cargo update'
alias ra='cargo audit'
alias ex='cargo expand'

