#!/usr/bin/env bash
set -euo pipefail

repo_root=$(git rev-parse --show-toplevel)

git diff --name-only -z \
  | grep -zE '\.(c|h|cpp|hpp)$' \
  | sort -zu \
  | while IFS= read -r -d '' f; do
        abs_f="$(realpath "$repo_root/$f")"
        echo "Formatting $abs_f"
        cubindent "$abs_f"
    done
