{
  "model": "Opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/hgryoo/.local/bin/snip hook"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node /home/hgryoo/.claude/plugins/cache/claude-dashboard/claude-dashboard/1.25.0/dist/index.js"
  },
  "enabledPlugins": {
    "oh-my-claudecode@omc": true,
    "claude-dashboard@claude-dashboard": true,
    "codex@openai-codex": true,
    "clangd@claude-code-lsps": true
  },
  "extraKnownMarketplaces": {
    "omc": {
      "source": {
        "source": "github",
        "repo": "Yeachan-Heo/oh-my-claudecode"
      }
    },
    "claude-dashboard": {
      "source": {
        "source": "github",
        "repo": "uppinote20/claude-dashboard"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "claude-code-lsps": {
      "source": {
        "source": "github",
        "repo": "boostvolt/claude-code-lsps"
      }
    }
  },
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "autoMemoryEnabled": false,
  "permissions": {
    "defaultMode": "acceptEdits"
  },
  "env": {
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
  }
}
