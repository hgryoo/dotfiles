[user]
    name = Hyung-Gyu Ryoo
    email = {{ .email }}
[core]
    editor = vim
[color]
    ui = auto
[alias]
    st = status
    co = checkout
    br = branch
    cm = commit
    df = diff
    lg = log --graph --pretty=format:'%C(yellow)%h%Creset %Cgreen%cd%Creset %C(bold blue)%an%Creset %C(auto)%d%Creset %s' --abbrev-commit --date=short

[credential "https://github.com"]
    helper =
    helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
    helper =
    helper = !/usr/bin/gh auth git-credential
