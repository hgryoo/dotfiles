# secrets.env.template — Copy to secrets.env and fill in values.
# secrets.env is git-ignored and never committed.
#
# Usage:
#   cp secrets.env.template secrets.env
#   $EDITOR secrets.env
#   bash auth.sh

# ---------------------------------------------------------------------------
# Anthropic
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# GitHub
# ---------------------------------------------------------------------------
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# HuggingFace
# ---------------------------------------------------------------------------
HUGGINGFACE_TOKEN=

# ---------------------------------------------------------------------------
# JIRA (CUBRID)
# ---------------------------------------------------------------------------
JIRA_URL=http://jira.cubrid.org
JIRA_USERNAME=
JIRA_API_TOKEN=

# ---------------------------------------------------------------------------
# rtk
# ---------------------------------------------------------------------------
RTK_API_KEY=

# ---------------------------------------------------------------------------
# Google Workspace (gws)
# OAuth credentials from Google Cloud Console.
# Run: gws auth setup   (to create a Cloud project)
# Then: gws auth login  (to authorize)
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
