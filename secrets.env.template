# secrets.env.template — Copy to secrets.env and fill in values.
# secrets.env is git-ignored and never committed.
#
# Usage:
#   cp secrets.env.template secrets.env
#   $EDITOR secrets.env
#   bash auth.sh

# ---------------------------------------------------------------------------
# Anthropic
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# GitHub
# ---------------------------------------------------------------------------
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# HuggingFace
# ---------------------------------------------------------------------------
HUGGINGFACE_TOKEN=

# ---------------------------------------------------------------------------
# JIRA (CUBRID)
# ---------------------------------------------------------------------------
JIRA_URL=http://jira.cubrid.org
JIRA_USERNAME=
JIRA_PASSWORD=

# ---------------------------------------------------------------------------
# Google Workspace (gws)
# OAuth credentials from Google Cloud Console.
# Run: gws auth setup   (to create a Cloud project)
# Then: gws auth login  (to authorize)
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Open Notebook (self-hosted NotebookLM alternative)
# Used by ~/open-notebook/docker-compose.yml via .env symlink.
# install_kb.sh auto-generates a random hex key if this is missing.
# ---------------------------------------------------------------------------
OPEN_NOTEBOOK_ENCRYPTION_KEY=
